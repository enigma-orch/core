# Shared infrastructure for the enigma stack.
# Both `agentic` (Python/FastAPI) and `backend` (Go/Fiber) connect to the
# services defined in docker-compose.yaml using these credentials.

# --- Postgres (pgvector) ---
POSTGRES_USER=drip
POSTGRES_PASSWORD=drip
POSTGRES_DB=drip
POSTGRES_PORT=5432

# Connection string used by the host `dbmate` CLI (Makefile loads this .env).
# 127.0.0.1 (not "localhost") — Docker Desktop on macOS forwards 5432 over
# IPv4 only; "localhost" can resolve to ::1 and fail with "connection refused".
# Each service still defines its own DATABASE_URL with the driver scheme it needs:
#   agentic  -> postgresql+asyncpg://drip:drip@127.0.0.1:5432/drip
#   backend  -> postgresql://drip:drip@127.0.0.1:5432/drip?sslmode=disable
DATABASE_URL=postgres://drip:drip@127.0.0.1:5432/drip?sslmode=disable

# --- RustFS (S3-compatible object store) ---
RUSTFS_ACCESS_KEY=drip-access-key
RUSTFS_SECRET_KEY=drip-secret-key

# --- Redis ---
REDIS_PORT=6379

# --- Neo4j (optional, profile: graph) ---
NEO4J_PASSWORD=change-me
