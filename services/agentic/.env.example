# Drip — environment template
#
# Copy to .env and replace placeholders. Required keys are marked [required]
# (the app will refuse to boot when these are missing in a non-development
# environment — see config.Settings.validate_required).

# ── App ───────────────────────────────────────────────────────────────────
# `development` enables debug defaults; any other value flips on strict
# validation (forces real SECRET_KEY / TOKEN_ENCRYPTION_KEY / CORS_ORIGINS).
APP_ENV=development
APP_DEBUG=true
# [required outside development] Strong random value for JWT signing.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
# [required outside development] Fernet key — encrypts OAuth tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
# Comma-separated origins. Wildcard `*` refused outside development.
CORS_ORIGINS=*
# Comma-separated hosts trusted for X-Forwarded-* headers, or "*"
PROXY_TRUSTED_HOSTS=*

# ── PostgreSQL ────────────────────────────────────────────────────────────
# [required] Default points at the local Postgres started by ../../infra.
# Run `make -C ../../infra up && make -C ../../infra db-up` to bring it up.
DATABASE_URL=postgresql+asyncpg://drip:drip@127.0.0.1:5432/drip

# ── RustFS (S3-compatible object storage) ─────────────────────────────────
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_PUBLIC_URL=http://localhost:9000
RUSTFS_BUCKET=drip-bucket
AWS_ACCESS_KEY_ID=drip-access-key
AWS_SECRET_ACCESS_KEY=drip-secret-key
AWS_DEFAULT_REGION=us-east-1

# ── Spotify OAuth (optional — disables Spotify login when unset) ──────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/auth/spotify/callback

# ── Google OAuth (optional — disables Google login / Calendar) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── Qwen (DashScope) — wardrobe detection + embeddings ────────────────────
# [required] qwen3.6-flash is the only allowed model (enforced by validator).
QWEN_API_KEY=
QWEN_MODEL=qwen3.6-flash
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Qwen Wan — outfit virtual try-on image generation ─────────────────────
# Falls back to QWEN_API_KEY when unset.
QWEN_WAN_API_KEY=
QWEN_WAN_MODEL=wan2.7-image
QWEN_WAN_BASE_HTTP_URL=https://dashscope-intl.aliyuncs.com/api/v1

# ── Google Custom Search (optional — used by the outfit scraper) ──────────
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ── remove.bg (optional — falls back to local rembg when unset/quota out) ─
REMOVE_BG_API_KEY=
REMOVE_BG_ENDPOINT=https://api.remove.bg/v1.0/removebg

# ── Other AI providers (optional, used by future features only) ───────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
