# Local Postgres is provided by ../../infra (see infra/docker-compose.yaml).
# Override these with your Neon connection strings in cloud environments.
POSTGRES_URL=postgresql://drip:drip@127.0.0.1:5432/drip?sslmode=disable
DATABASE_URL=postgresql://drip:drip@127.0.0.1:5432/drip?sslmode=disable

SERVER_PORT=8080
SERVER_HOST=localhost
INTERNAL_API_TOKEN=change-me-for-shared-environments
ENVIRONMENT=development

# Required. Generate: openssl rand -hex 32
JWT_SECRET=dev-secret-change-me-in-production
ARGON2_SALT=enigma-salt
CORS_ORIGINS=http://localhost:5500

# Optional graph store (derived from Postgres via outbox).
# Leave GRAPH_ENABLED=false to skip Neo4j entirely in local dev.
# Start it with: docker compose -f ../../infra/docker-compose.yaml --profile graph up -d neo4j
GRAPH_ENABLED=false
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
GRAPH_POLL_INTERVAL=2s
GRAPH_BATCH_SIZE=100
